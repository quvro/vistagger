{
  "$schema": "https://raw.githubusercontent.com/nicholasio/tauri-docs/refs/heads/dev/src/content/docs/_schema/config.schema.json",
  "productName": "VisTagger",
  "version": "0.1.0",
  "identifier": "com.vistagger.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "VisTagger - 绘画参考工具",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": ["**"]
    },
    "global-shortcut": {},
    "shell": {
      "open": true
    }
  }
}
